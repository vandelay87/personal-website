{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": true
  },
  "include": [
    "vite.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.mdx",
    "src/mdx.d.ts",
    "eslint.config.js",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "sitemap-plugin.ts",
    "sitemap-plugin.test.ts",
    "plugins/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "coverage"]
}
