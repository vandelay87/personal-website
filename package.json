{
  "name": "personal-website",
  "private": true,
  "version": "1.11.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/lambda-handler.ts --outDir dist/server",
    "build:prod": "cp public/robots.prod.txt public/robots.txt && pnpm build:client && pnpm build:server && cp dist/client/index.html dist/server/index.html",
    "build:dev": "cp public/robots.dev.txt public/robots.txt && vite build",
    "lint": "eslint .",
    "check:descendant-selectors": "node scripts/check-descendant-selectors.ts",
    "preview": "vite preview",
    "format": "prettier --write . && eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@mdx-js/react": "^3.1.0",
    "@shikijs/rehype": "^4.3.1",
    "@shikijs/types": "4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "rehype-mermaid": "^3.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.1.4",
    "vite-imagetools": "^10.0.1",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  }
}